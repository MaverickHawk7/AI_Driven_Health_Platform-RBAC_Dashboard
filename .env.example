# ===========================================
# Railway Deployment — Required Environment Variables
# ===========================================

# Node environment (Railway sets this automatically)
NODE_ENV=production

# PostgreSQL — provision a Postgres service in Railway, it auto-sets this
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session secret — generate with: openssl rand -base64 32
SESSION_SECRET=your-random-secret-here

# Encryption key for patient PII — generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-key-here

# CORS — your Railway app URL (e.g., https://your-app.up.railway.app)
ALLOWED_ORIGINS=https://your-app.up.railway.app

# ===========================================
# Optional
# ===========================================

# Redis — provision a Redis service in Railway, it auto-sets this
# REDIS_URL=redis://default:password@host:6379

# Port — Railway sets this automatically, don't set manually
# PORT=5000

# AI Services — disable if not available in production
YOLO_ENABLED=false
OLLAMA_ENABLED=false
# OPENROUTER_API_KEY=your-key-here
